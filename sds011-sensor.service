[Unit]
Description=SDS011 Sensor Sender Service
After=network.target

[Service]
Type=simple
User=walker
WorkingDirectory=/home/walker/sds011-sensor
ExecStart=/home/walker/sds011-sensor/venv/bin/python /home/walker/sds011-sensor/sensor_node.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
